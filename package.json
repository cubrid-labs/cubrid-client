{
  "name": "cubrid-client",
  "version": "1.1.0",
  "description": "Modern TypeScript-first client for CUBRID.",
  "license": "MIT",
  "author": "Gyeongjun Paik <paikend@gmail.com>",
  "contributors": [
    { "name": "Gyeongjun Paik", "email": "paikend@gmail.com" },
    { "name": "Yeongseon Choe", "email": "yeongseon.choe@gmail.com" }
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "node --import tsx --test 'tests/client.test.ts' 'tests/protocol.test.ts' 'tests/native-adapter.test.ts' 'tests/connection.test.ts' 'tests/connection-string.test.ts' 'tests/query-utils.test.ts'",
    "test:integration": "node --import tsx --test 'tests/integration.test.ts'",
    "test:all": "node --import tsx --test 'tests/*.test.ts'",
    "test:coverage": "c8 --reporter=text --reporter=lcov node --import tsx --test 'tests/client.test.ts' 'tests/protocol.test.ts' 'tests/native-adapter.test.ts' 'tests/connection.test.ts' 'tests/connection-string.test.ts' 'tests/query-utils.test.ts'",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run test:coverage"
  },
  "keywords": [
    "cubrid",
    "database",
    "typescript",
    "nodejs",
    "client"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cubrid-labs/cubrid-client.git"
  },
  "homepage": "https://github.com/cubrid-labs/cubrid-client#readme",
  "bugs": {
    "url": "https://github.com/cubrid-labs/cubrid-client/issues"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "c8": "^11.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.20.3",
    "typescript": "^6.0.2"
  }
}
